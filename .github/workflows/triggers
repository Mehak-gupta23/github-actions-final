name: Triggering Events

on:
  # Runs when code is pushed to the main branch
  push:
    branches:
      - main

  # Runs when a pull request is opened or updated
  pull_request:
    types:
      - opened
      - synchronize
      - reopened

  # Runs manually from the Actions tab
  workflow_dispatch:

jobs:
  show-trigger:
    name: Show Workflow Trigger
    runs-on: ubuntu-24.04

    steps:
      - name: Print event name
        run: echo "This workflow was triggered by $GITHUB_EVENT_NAME"

      - name: Explain trigger
        run: |
          echo "A trigger is an event that starts a GitHub Actions workflow."
          echo "Examples: push, pull_request, release, schedule, workflow_dispatch."
